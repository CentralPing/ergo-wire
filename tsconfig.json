{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "es2022",
    "declaration": true,
    "emitDeclarationOnly": true,
    "skipLibCheck": true,
    "outDir": "types"
  },
  "include": ["index.js", "lib/**/*.js"],
  "exclude": ["**/*.spec.*.js"]
}
